---
import IconMail from "@/assets/icons/IconMail.svg";

interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

<section
  id="newsletter"
  class:list={[compact ? "py-6 text-center" : "pt-8 pb-6"]}
>
  <h2 class:list={[compact ? "text-base font-medium" : "text-2xl font-semibold tracking-wide"]}>
    {compact ? "📮 订阅通讯" : "Newsletter"}
  </h2>
  <p class:list={["mt-2 mb-4", compact ? "text-sm text-foreground/60" : "text-foreground/80"]}>
    {compact
      ? "分享真实的创业经历与思考，没有废话随时退订"
      : "订阅邮件列表，第一时间收到新文章通知。不发垃圾邮件，随时退订。"}
  </p>
  <form id="newsletter-form" class:list={[
    "flex items-stretch rounded-full border border-border max-sm:flex-col max-sm:gap-2 max-sm:rounded-none max-sm:border-none",
    compact ? "mx-auto max-w-md bg-muted/30 max-sm:bg-transparent" : "bg-background/50 max-sm:bg-transparent",
  ]}>
    <div class="relative flex flex-1 items-center pl-4 max-sm:w-full max-sm:pl-0">
      <IconMail
        class="absolute top-1/2 left-4 -translate-y-1/2 text-foreground/30"
        width={16}
        height={16}
      />
      <input
        type="email"
        name="email"
        required
        placeholder="your@email.com"
        class="w-full border-none bg-transparent py-2.5 pr-2 pl-6 text-sm text-foreground placeholder:text-foreground/30 focus:outline-none max-sm:rounded-lg max-sm:border max-sm:border-border max-sm:bg-muted/30 max-sm:py-3 max-sm:pl-10"
      />
    </div>
    <button
      type="submit"
      class="focus-outline m-1 rounded-full bg-foreground/90 px-5 py-2 text-sm font-medium text-background transition-colors hover:bg-foreground max-sm:m-0 max-sm:rounded-lg max-sm:py-3"
    >
      订阅
    </button>
  </form>
  <p id="newsletter-msg" class="mt-2 hidden text-sm"></p>
</section>

<script>
  document.addEventListener("astro:page-load", () => {
    const form = document.querySelector("#newsletter-form") as HTMLFormElement;
    const msg = document.querySelector("#newsletter-msg") as HTMLElement;
    if (!form || !msg) return;

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const email = new FormData(form).get("email") as string;
      const btn = form.querySelector("button") as HTMLButtonElement;

      btn.disabled = true;
      btn.textContent = "提交中...";
      msg.classList.add("hidden");

      try {
        const res = await fetch("/api/subscribe", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ email }),
        });
        const data = await res.json();

        msg.classList.remove("hidden");
        if (res.ok) {
          msg.textContent = "🎉 订阅成功！感谢关注。";
          msg.className = "mt-2 text-sm text-green-600 dark:text-green-400";
          form.reset();
        } else {
          msg.textContent = data.error || "订阅失败，请稍后再试。";
          msg.className = "mt-2 text-sm text-red-500";
        }
      } catch {
        msg.classList.remove("hidden");
        msg.textContent = "网络错误，请稍后再试。";
        msg.className = "mt-2 text-sm text-red-500";
      } finally {
        btn.disabled = false;
        btn.textContent = "订阅";
      }
    });
  });
</script>
